APP_ENV=dev

# Comma-separated origins. In dev you can leave it empty and the app will allow "*".
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional in dev. Set it in production.
# API_KEY=replace-with-strong-service-key

# Business data store.
BUSINESS_DATABASE_URL=sqlite+pysqlite:///./after_sales_mvp.db

# Runtime state store. Leave empty in local dev to use the in-memory state store.
# AGENT_RUNTIME_DATABASE_URL=postgresql://agent:agent@127.0.0.1:5432/agent_runtime

AUTO_CREATE_SCHEMA=true

# Supported values: deepseek, openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30.0
LLM_MAX_RETRIES=2

# Required when llm_provider=deepseek.
DEEPSEEK_API_KEY=replace-me

# Optional example provider. Required when llm_provider=openai.
# OPENAI_API_KEY=replace-me

MAX_STEPS=4
APPROVAL_TIMEOUT_SECONDS=900

# Optional MCP tool servers as a JSON object. Supports HTTP and stdio transports.
# MCP_SERVERS={"weather":{"transport":"http","url":"http://localhost:8000/mcp"},"math":{"transport":"stdio","command":"python","args":["./examples/math_server.py"]}}
